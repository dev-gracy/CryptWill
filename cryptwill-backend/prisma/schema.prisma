generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum KYCStatus {
  NOT_SUBMITTED
  SUBMITTED
  VERIFIED
  REJECTED
}

enum Plan {
  FREE
  PRO
  ENTERPRISE
}

enum ContractStatus {
  NOT_DEPLOYED
  ACTIVE
  TRIGGERED
  EXECUTING
  EXECUTED
  CANCELLED
}

enum AssetType {
  STELLAR_WALLET
  CUSTOM_TOKEN
  NFT
  DOCUMENT
}

enum GuardianStatus {
  INVITED
  ACTIVE
  DECLINED
  REMOVED
}

enum BeneficiaryStatus {
  INVITED
  ACTIVE
  DECLINED
}

enum VoteType {
  APPROVE
  DENY
}
enum NotificationType {
  EMAIL_OTP
  WELCOME
  PASSWORD_RESET
  CHECKIN_REMINDER_EARLY
  CHECKIN_REMINDER_URGENT
  CHECKIN_REMINDER_FINAL
  CHECKIN_CONFIRMED
  CHECKIN_MISSED
  GUARDIAN_INVITE
  GUARDIAN_ACTIVATED
  GUARDIAN_ALERT
  GUARDIAN_VOTE_UPDATE
  GUARDIAN_QUORUM_REACHED
  GUARDIAN_DENIED
  BENEFICIARY_INVITE
  BENEFICIARY_INHERITANCE_STARTED
  BENEFICIARY_ASSET_RECEIVED
  CONTRACT_DEPLOYED
  SUBSCRIPTION_CONFIRMED
  SUBSCRIPTION_EXPIRING
}
enum NotificationChannel {
  EMAIL
  SMS
}
enum NotificationStatus {
  QUEUED
  SENT
  FAILED
}
enum SubscriptionStatus {
  ACTIVE
  CANCELLED
  EXPIRED
  PAST_DUE
}

model User {
  id                String    @id @default(uuid())
  email             String    @unique
  passwordHash      String
  fullName          String
  phone             String?
  dateOfBirth       DateTime?
  country           String?
  walletAddress     String?
  kycStatus         KYCStatus @default(NOT_SUBMITTED)
  kycDocumentUrl    String?
  kycDocumentType   String?
  bankDeclaration   String?
  plan              Plan      @default(FREE)
  isVerified        Boolean   @default(false)
  isOnboarded       Boolean   @default(false)
  termsAcceptedAt   DateTime?
  termsVersion      String?
  otpCode           String?
  otpExpiresAt      DateTime?
  refreshToken      String?
  createdAt         DateTime  @default(now())
  updatedAt         DateTime  @updatedAt

  assets            Asset[]
  beneficiaries     Beneficiary[]
  guardians         Guardian[]
  contract          Contract?
  vaultFiles        VaultFile[]
  notifications     Notification[]
  subscription      Subscription?
  checkIns          CheckIn[]
  termsAcceptances  TermsAcceptance[]
  rulebook          UserRulebook?
}

model Asset {
  id                  String    @id @default(uuid())
  userId              String
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetName           String
  assetType           AssetType
  walletAddress       String?
  tokenCode           String?
  estimatedValueUsd   Decimal?
  ipfsHash            String?
  encryptionKeyRef    String?
  releaseDay          Int       @default(0)
  specialInstructions String?
  isActive            Boolean   @default(true)
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  assignments         AssetBeneficiaryAssignment[]
  vaultFiles          VaultFile[]
}

model Beneficiary {
  id                  String            @id @default(uuid())
  userId              String
  user                User              @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName            String
  email               String
  phone               String?
  walletAddress       String?
  verificationToken   String?
  status              BeneficiaryStatus @default(INVITED)
  passwordHash        String?
  createdAt           DateTime          @default(now())
  updatedAt           DateTime          @updatedAt

  assignments         AssetBeneficiaryAssignment[]
  vaultFiles          VaultFile[]
}

model AssetBeneficiaryAssignment {
  id              String      @id @default(uuid())
  assetId         String
  asset           Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  beneficiaryId   String
  beneficiary     Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  percentage      Int         @default(100)
  notes           String?
  createdAt       DateTime    @default(now())

  @@unique([assetId, beneficiaryId])
}

model Guardian {
  id            String        @id @default(uuid())
  userId        String
  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName      String
  email         String
  phone         String?
  inviteToken   String?
  status        GuardianStatus @default(INVITED)
  passwordHash  String?
  acceptedAt    DateTime?
  createdAt     DateTime      @default(now())
  updatedAt     DateTime      @updatedAt

  votes         GuardianVote[]
}

model GuardianVote {
  id          String    @id @default(uuid())
  contractId  String
  contract    Contract  @relation(fields: [contractId], references: [id])
  guardianId  String
  guardian    Guardian  @relation(fields: [guardianId], references: [id])
  vote        VoteType
  notes       String?
  votedAt     DateTime  @default(now())

  @@unique([contractId, guardianId])
}

model Contract {
  id                  String        @id @default(uuid())
  userId              String        @unique
  user                User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  contractAddress     String?
  network             String        @default("testnet")
  status              ContractStatus @default(NOT_DEPLOYED)
  checkinIntervalDays Int           @default(30)
  guardianQuorum      Int           @default(3)
  missedCheckinCount  Int           @default(0)
  deployedAt          DateTime?
  lastCheckinAt       DateTime?
  nextCheckinDue      DateTime?
  triggerStartedAt    DateTime?
  executedAt          DateTime?
  stellarTxHash       String?
  createdAt           DateTime      @default(now())
  updatedAt           DateTime      @updatedAt

  checkIns            CheckIn[]
  votes               GuardianVote[]
}

model CheckIn {
  id                  String    @id @default(uuid())
  contractId          String
  contract            Contract  @relation(fields: [contractId], references: [id])
  userId              String
  user                User      @relation(fields: [userId], references: [id])
  transactionHash     String
  proofOfLifeTokenId  String?
  stellarExplorerUrl  String?
  method              String    @default("manual")
  checkedInAt         DateTime  @default(now())
}

model VaultFile {
  id                    String      @id @default(uuid())
  userId                String
  user                  User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId               String?
  asset                 Asset?      @relation(fields: [assetId], references: [id])
  assignedBeneficiaryId String?
  beneficiary           Beneficiary? @relation(fields: [assignedBeneficiaryId], references: [id])
  fileName              String
  fileSizeBytes         Int
  fileType              String
  ipfsHash              String
  isEncrypted           Boolean     @default(true)
  encryptionKeyRef      String?
  uploadedAt            DateTime    @default(now())
}

model Subscription {
  id                      String              @id @default(uuid())
  userId                  String              @unique
  user                    User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                    Plan                @default(FREE)
  razorpaySubscriptionId  String?
  razorpayCustomerId      String?
  status                  SubscriptionStatus  @default(ACTIVE)
  startedAt               DateTime            @default(now())
  expiresAt               DateTime?
  cancelledAt             DateTime?
  createdAt               DateTime            @default(now())
  updatedAt               DateTime            @updatedAt
}

model Notification {
  id              String                @id @default(uuid())
  userId          String
  user            User                  @relation(fields: [userId], references: [id], onDelete: Cascade)
  type            NotificationType
  channel         NotificationChannel
  status          NotificationStatus    @default(QUEUED)
  recipient       String
  subject         String?
  body            String
  metadata        Json?
  sentAt          DateTime?
  failureReason   String?
  createdAt       DateTime              @default(now())
}

model TermsAcceptance {
  id          String    @id @default(uuid())
  userId      String
  user        User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  version     String
  acceptedAt  DateTime  @default(now())
  ipAddress   String?
  userAgent   String?
}

model UserRulebook {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rules     Json     @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
