generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = "file:./dev.db"
}

model User {
  id              String    @id @default(uuid())
  email           String    @unique
  passwordHash    String
  fullName        String
  phone           String?
  dateOfBirth     DateTime?
  country         String?
  walletAddress   String?
  kycStatus       String    @default("NOT_SUBMITTED")
  kycDocumentUrl  String?
  kycDocumentType String?
  bankDeclaration String?
  plan            String    @default("FREE")
  isVerified      Boolean   @default(false)
  isOnboarded     Boolean   @default(false)
  termsAcceptedAt DateTime?
  termsVersion    String?
  otpCode         String?
  otpExpiresAt    DateTime?
  refreshToken    String?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  assets           Asset[]
  beneficiaries    Beneficiary[]
  guardians        Guardian[]
  contract         Contract?
  vaultFiles       VaultFile[]
  notifications    Notification[]
  subscription     Subscription?
  checkIns         CheckIn[]
  termsAcceptances TermsAcceptance[]
  rulebook         UserRulebook?
}

model Asset {
  id                  String   @id @default(uuid())
  userId              String
  user                User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetName           String
  assetType           String
  walletAddress       String?
  tokenCode           String?
  estimatedValueUsd   Float?
  ipfsHash            String?
  encryptionKeyRef    String?
  releaseDay          Int      @default(0)
  specialInstructions String?
  isActive            Boolean  @default(true)
  createdAt           DateTime @default(now())
  updatedAt           DateTime @updatedAt

  assignments AssetBeneficiaryAssignment[]
  vaultFiles  VaultFile[]
}

model Beneficiary {
  id                String   @id @default(uuid())
  userId            String
  user              User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName          String
  email             String
  phone             String?
  walletAddress     String?
  verificationToken String?
  status            String   @default("INVITED")
  passwordHash      String?
  createdAt         DateTime @default(now())
  updatedAt         DateTime @updatedAt

  assignments AssetBeneficiaryAssignment[]
  vaultFiles  VaultFile[]
}

model AssetBeneficiaryAssignment {
  id            String      @id @default(uuid())
  assetId       String
  asset         Asset       @relation(fields: [assetId], references: [id], onDelete: Cascade)
  beneficiaryId String
  beneficiary   Beneficiary @relation(fields: [beneficiaryId], references: [id], onDelete: Cascade)
  percentage    Int         @default(100)
  notes         String?
  createdAt     DateTime    @default(now())

  @@unique([assetId, beneficiaryId])
}

model Guardian {
  id           String    @id @default(uuid())
  userId       String
  user         User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  fullName     String
  email        String
  phone        String?
  inviteToken  String?
  status       String    @default("INVITED")
  passwordHash String?
  acceptedAt   DateTime?
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt

  votes GuardianVote[]
}

model GuardianVote {
  id         String   @id @default(uuid())
  contractId String
  contract   Contract @relation(fields: [contractId], references: [id])
  guardianId String
  guardian   Guardian @relation(fields: [guardianId], references: [id])
  vote       String
  notes      String?
  votedAt    DateTime @default(now())

  @@unique([contractId, guardianId])
}

model Contract {
  id                  String    @id @default(uuid())
  userId              String    @unique
  user                User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  contractAddress     String?
  network             String    @default("testnet")
  status              String    @default("NOT_DEPLOYED")
  checkinIntervalDays Int       @default(30)
  guardianQuorum      Int       @default(3)
  missedCheckinCount  Int       @default(0)
  deployedAt          DateTime?
  lastCheckinAt       DateTime?
  nextCheckinDue      DateTime?
  triggerStartedAt    DateTime?
  executedAt          DateTime?
  stellarTxHash       String?
  createdAt           DateTime  @default(now())
  updatedAt           DateTime  @updatedAt

  checkIns CheckIn[]
  votes    GuardianVote[]
}

model CheckIn {
  id                 String   @id @default(uuid())
  contractId         String
  contract           Contract @relation(fields: [contractId], references: [id])
  userId             String
  user               User     @relation(fields: [userId], references: [id])
  transactionHash    String
  proofOfLifeTokenId String?
  stellarExplorerUrl String?
  method             String   @default("manual")
  checkedInAt        DateTime @default(now())
}

model VaultFile {
  id                    String       @id @default(uuid())
  userId                String
  user                  User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  assetId               String?
  asset                 Asset?       @relation(fields: [assetId], references: [id])
  assignedBeneficiaryId String?
  beneficiary           Beneficiary? @relation(fields: [assignedBeneficiaryId], references: [id])
  fileName              String
  fileSizeBytes         Int
  fileType              String
  ipfsHash              String
  isEncrypted           Boolean      @default(true)
  encryptionKeyRef      String?
  uploadedAt            DateTime     @default(now())
}

model Subscription {
  id                     String    @id @default(uuid())
  userId                 String    @unique
  user                   User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  plan                   String    @default("FREE")
  razorpaySubscriptionId String?
  razorpayCustomerId     String?
  status                 String    @default("ACTIVE")
  startedAt              DateTime  @default(now())
  expiresAt              DateTime?
  cancelledAt            DateTime?
  createdAt              DateTime  @default(now())
  updatedAt              DateTime  @updatedAt
}

model Notification {
  id            String    @id @default(uuid())
  userId        String
  user          User      @relation(fields: [userId], references: [id], onDelete: Cascade)
  type          String
  channel       String
  status        String    @default("QUEUED")
  recipient     String
  subject       String?
  body          String
  metadata      String?
  sentAt        DateTime?
  failureReason String?
  createdAt     DateTime  @default(now())
}

model TermsAcceptance {
  id         String   @id @default(uuid())
  userId     String
  user       User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  version    String
  acceptedAt DateTime @default(now())
  ipAddress  String?
  userAgent  String?
}

model UserRulebook {
  id        String   @id @default(uuid())
  userId    String   @unique
  user      User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  rules     String   @default("[]")
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
