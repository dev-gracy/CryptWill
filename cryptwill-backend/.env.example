NODE_ENV=development
PORT=5000
FRONTEND_URL=http://localhost:5173
DATABASE_URL=postgresql://user:pass@host:5432/cryptwill
REDIS_URL=rediss://default:password@host.upstash.io:6379
JWT_SECRET=minimum_32_character_secret_key_here
JWT_EXPIRES_IN=7d
REFRESH_TOKEN_SECRET=another_32_character_secret_here
REFRESH_TOKEN_EXPIRES_IN=30d
RESEND_API_KEY=re_xxxxxxxxxxxx
EMAIL_FROM=CryptWill <onboarding@resend.dev>
# Optional SMTP alternative (Brevo or any SMTP provider)
# BREVO_SMTP_HOST=smtp-relay.brevo.com
# BREVO_SMTP_PORT=587
# BREVO_SMTP_USER=your_brevo_login
# BREVO_SMTP_PASS=your_brevo_smtp_key
# BREVO_FROM=CryptWill <noreply@yourdomain.com>
RUN_WORKERS=false
# Optional dev-only fallback when email is not configured.
# Keeps OTP 123456 and password 12345678 working in non-production.
ALLOW_DEV_AUTH_FALLBACK=true
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token
TWILIO_PHONE_NUMBER=+1234567890
STELLAR_NETWORK=testnet
STELLAR_HORIZON_URL=https://horizon-testnet.stellar.org
STELLAR_RPC_URL=https://soroban-testnet.stellar.org
POOL_WALLET_PUBLIC=G_your_pool_wallet_public_key
POOL_WALLET_SECRET=S_your_pool_wallet_secret_key
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key
PINATA_JWT=your_pinata_jwt
RAZORPAY_KEY_ID=rzp_test_xxxxxxxxxx
RAZORPAY_KEY_SECRET=your_razorpay_secret
RAZORPAY_WEBHOOK_SECRET=your_webhook_secret
