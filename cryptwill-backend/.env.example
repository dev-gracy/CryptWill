POOL_WALLET_PUBLIC=G_your_pool_wallet_public_key
POOL_WALLET_SECRET=S_your_pool_wallet_secret_key
PINATA_API_KEY=your_pinata_api_key
PINATA_SECRET_KEY=your_pinata_secret_key
